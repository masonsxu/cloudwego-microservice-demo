# =============================================================================
# CloudWeGo 微服务基础设施 - Kubernetes 资源清单
# =============================================================================
# 用途：通过 podman kube play 启动本地开发基础设施（用于学习 K8s）
# 包含：PostgreSQL、etcd、Redis、RustFS、Jaeger
#
# 使用方式：
#   1. 修改下方 Secret 中的密码占位值（POSTGRES_PASSWORD/RUSTFS_SECRET_KEY/REDIS_PASSWORD）
#   2. 启动：     podman kube play docker/pod.yml
#   3. 查看 Pod： podman pod ps
#   4. 查看容器： podman ps
#   5. 查看日志： podman logs <container>
#   6. 停止清理： podman kube play --down docker/pod.yml
#   7. 全量销毁(含PVC数据)： podman kube play --down --force docker/pod.yml
#
# K8s 资源对照（学习要点）：
#   - Secret                  敏感配置（密码、密钥），等同于 .env 中的密码部分
#   - PersistentVolumeClaim   持久卷声明，等同于 docker-compose 的命名卷
#   - Deployment              工作负载控制器，管理 Pod 副本（声明式滚动更新）
#   - Service                 服务发现，提供集群内稳定 DNS（同 namespace 内 <name>:<port>）
#
# 注意事项：
#   - hostPort 将容器端口直接绑定到宿主机端口（等价于 compose 的 ports 映射）
#     这是 podman kube play 在本地最简单的"暴露到宿主机"方式
#   - 真实 K8s 集群中通常不用 hostPort，而是 Service(NodePort/LoadBalancer) + Ingress
#   - podman kube play 对 Service 的支持仅限基础 DNS 解析；跨 Pod 通信也可直接使用
#     hostPort + 宿主机 localhost（与本项目 Go 服务在宿主机运行的场景一致）
# =============================================================================

---
# -----------------------------------------------------------------------------
# Secret：敏感配置
# stringData 会自动 base64 编码后存入 data；生产环境请用 SealedSecrets 或 Vault
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: cloudwego-secrets
  labels:
    app.kubernetes.io/part-of: cloudwego-scaffold
type: Opaque
stringData:
  POSTGRES_USER: Admin
  POSTGRES_PASSWORD: CHANGE_ME_postgres   # ← 修改为强密码
  POSTGRES_DB: identity_srv
  RUSTFS_ACCESS_KEY: Admin
  RUSTFS_SECRET_KEY: CHANGE_ME_rustfs     # ← 修改为强密码（最少 8 位）
  REDIS_PASSWORD: CHANGE_ME_redis         # ← 修改为强密码
  JWT_SIGNING_KEY: CHANGE_ME_jwt          # ← 修改为随机字符串（openssl rand -base64 32）

---
# -----------------------------------------------------------------------------
# PVC：PostgreSQL 数据持久化
# -----------------------------------------------------------------------------
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: postgres-data
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: 10Gi

---
# -----------------------------------------------------------------------------
# PVC：RustFS 对象存储持久化
# -----------------------------------------------------------------------------
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: rustfs-data
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: 20Gi

---
# -----------------------------------------------------------------------------
# PVC：Redis AOF 持久化
# -----------------------------------------------------------------------------
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: redis-data
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: 5Gi

---
# =============================================================================
# PostgreSQL：Deployment + Service
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  labels:
    app: postgres
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
        - name: postgres
          image: m.daocloud.io/docker.io/library/postgres:17
          ports:
            - containerPort: 5432
              hostPort: 5432
          env:
            - name: POSTGRES_USER
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: POSTGRES_USER
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: POSTGRES_PASSWORD
            - name: POSTGRES_DB
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: POSTGRES_DB
            - name: POSTGRES_INITDB_ARGS
              value: "--encoding=UTF-8 --lc-collate=C --lc-ctype=C"
            - name: PGDATA
              value: /var/lib/postgresql/data/pgdata
            - name: POSTGRES_EXTENSIONS
              value: hstore,uuid-ossp,pg_stat_statements
            - name: TERM
              value: xterm
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - pg_isready -U "$POSTGRES_USER" -d postgres
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: postgres-data

---
apiVersion: v1
kind: Service
metadata:
  name: postgres
spec:
  selector:
    app: postgres
  ports:
    - port: 5432
      targetPort: 5432
      protocol: TCP

---
# =============================================================================
# etcd：Deployment + Service
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: etcd
  labels:
    app: etcd
spec:
  replicas: 1
  selector:
    matchLabels:
      app: etcd
  template:
    metadata:
      labels:
        app: etcd
    spec:
      containers:
        - name: etcd
          image: quay.io/coreos/etcd:v3.6.0
          ports:
            - containerPort: 2379
              hostPort: 2379
          env:
            - name: ALLOW_NONE_AUTHENTICATION
              value: "yes"
            - name: ETCD_ADVERTISE_CLIENT_URLS
              value: http://etcd:2379
            - name: ETCD_LISTEN_CLIENT_URLS
              value: http://0.0.0.0:2379
          readinessProbe:
            exec:
              command: [etcdctl, endpoint, health]
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5

---
apiVersion: v1
kind: Service
metadata:
  name: etcd
spec:
  selector:
    app: etcd
  ports:
    - port: 2379
      targetPort: 2379

---
# =============================================================================
# RustFS：Deployment + Service
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: rustfs
  labels:
    app: rustfs
spec:
  replicas: 1
  selector:
    matchLabels:
      app: rustfs
  template:
    metadata:
      labels:
        app: rustfs
    spec:
      containers:
        - name: rustfs
          image: m.daocloud.io/docker.io/rustfs/rustfs:1.0.0-alpha.90
          ports:
            - name: api
              containerPort: 9000
              hostPort: 9000
            - name: console
              containerPort: 9001
              hostPort: 9001
          env:
            - name: RUSTFS_ACCESS_KEY
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: RUSTFS_ACCESS_KEY
            - name: RUSTFS_SECRET_KEY
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: RUSTFS_SECRET_KEY
            - name: RUSTFS_CONSOLE_ENABLE
              value: "true"
          volumeMounts:
            - name: data
              mountPath: /data
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - netstat -tuln | grep 9000 || exit 1
            initialDelaySeconds: 20
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 5
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: rustfs-data

---
apiVersion: v1
kind: Service
metadata:
  name: rustfs
spec:
  selector:
    app: rustfs
  ports:
    - name: api
      port: 9000
      targetPort: 9000
    - name: console
      port: 9001
      targetPort: 9001

---
# =============================================================================
# Redis：Deployment + Service
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: redis
  labels:
    app: redis
spec:
  replicas: 1
  selector:
    matchLabels:
      app: redis
  template:
    metadata:
      labels:
        app: redis
    spec:
      containers:
        - name: redis
          image: m.daocloud.io/docker.io/library/redis:8.4.0
          ports:
            - containerPort: 6379
              hostPort: 6379
          command: [sh, -c]
          args:
            # exec 让 redis-server 替换 sh 成为 PID 1，避免 sh 不转发 SIGTERM 导致关闭时只能 SIGKILL
            - 'exec redis-server --appendonly yes --requirepass "$REDIS_PASSWORD"'
          env:
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: REDIS_PASSWORD
          volumeMounts:
            - name: data
              mountPath: /data
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - redis-cli -a "$REDIS_PASSWORD" ping | grep PONG
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
      # AOF 同步在大数据量下可能 >10s，给 redis 足够时间优雅关闭
      terminationGracePeriodSeconds: 30
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: redis-data

---
apiVersion: v1
kind: Service
metadata:
  name: redis
spec:
  selector:
    app: redis
  ports:
    - port: 6379
      targetPort: 6379

---
# =============================================================================
# Jaeger：Deployment + Service（链路追踪）
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: jaeger
  labels:
    app: jaeger
spec:
  replicas: 1
  selector:
    matchLabels:
      app: jaeger
  template:
    metadata:
      labels:
        app: jaeger
    spec:
      containers:
        - name: jaeger
          image: m.daocloud.io/docker.io/jaegertracing/jaeger:2.12.0
          ports:
            - name: ui
              containerPort: 16686
              hostPort: 16686
            - name: otlp-grpc
              containerPort: 4317
              hostPort: 4317
            - name: otlp-http
              containerPort: 4318
              hostPort: 4318
          env:
            - name: COLLECTOR_OTLP_ENABLED
              value: "true"
          readinessProbe:
            httpGet:
              path: /status
              port: 13133
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5

---
apiVersion: v1
kind: Service
metadata:
  name: jaeger
spec:
  selector:
    app: jaeger
  ports:
    - name: ui
      port: 16686
      targetPort: 16686
    - name: otlp-grpc
      port: 4317
      targetPort: 4317
    - name: otlp-http
      port: 4318
      targetPort: 4318

---
# =============================================================================
# 应用层环境变量 ConfigMap
# 仅放置容器化场景与默认值不同的关键配置；其余使用代码中的 defaults.go
# =============================================================================
apiVersion: v1
kind: ConfigMap
metadata:
  name: cloudwego-app-env
data:
  # ---- 服务发现 / 中间件地址（容器内通过 Service 名解析）----
  ETCD_ADDRESS: etcd:2379
  REDIS_ADDRESS: redis:6379
  TRACING_ENABLED: "true"
  TRACING_ENDPOINT: jaeger:4317

  # ---- 数据库（identity_srv 用）----
  DB_HOST: postgres
  DB_PORT: "5432"
  DB_TIMEZONE: Asia/Shanghai
  DB_SSLMODE: disable

  # ---- 对象存储（identity_srv 用）----
  # 容器内访问端点
  LOGO_STORAGE_S3_ENDPOINT: http://rustfs:9000
  # 浏览器访问端点（用于生成预签名 URL）
  LOGO_STORAGE_S3_PUBLIC_ENDPOINT: http://localhost:9000

  # ---- 网关：JWT 认证（常变项，部署时按需修改）----
  # 跳过认证的路径（逗号分隔），新增无需认证的端点时需同步追加
  JWT_SKIP_PATHS: "/.well-known/openid-configuration,/keys,/oauth/token,/authorize,/authorize/callback,/login,/revoke,/oauth/introspect,/userinfo,/api/v1/identity/auth/login,/api/v1/identity/auth/refresh,/ping,/health,/metrics,/swagger/*"
  # JWT Token 有效期
  JWT_TIMEOUT: 30m
  JWT_MAX_REFRESH: 168h

  # ---- 网关：CORS（部署时按实际前端地址修改）----
  CORS_ALLOW_ORIGINS: "http://localhost:5173"

  # ---- 日志路径（容器内 appuser 有写权限的目录）----
  LOG_OUTPUT: stdout

  # ---- 调试开关（生产环境建议注释或设为 false）----
  SERVER_DEBUG: "false"

---
# =============================================================================
# identity_srv：Deployment + Service（Kitex RPC 身份认证服务）
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: identity-srv
  labels:
    app: identity-srv
spec:
  replicas: 1
  selector:
    matchLabels:
      app: identity-srv
  template:
    metadata:
      labels:
        app: identity-srv
    spec:
      # 启动顺序由 K8s 自动重试保障：基础设施未 ready 时启动失败 → 自动重启
      restartPolicy: Always
      containers:
        - name: identity-srv
          image: localhost/identity-srv:latest
          imagePullPolicy: Never            # 仅使用本地构建的镜像，避免 podman 误把 localhost/ 当 registry
          ports:
            - name: rpc
              containerPort: 8891
              hostPort: 8891
            - name: health
              containerPort: 10000
              hostPort: 10000
          envFrom:
            - configMapRef:
                name: cloudwego-app-env
          env:
            # 数据库账号密码（来自 Secret）
            - name: DB_USERNAME
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: POSTGRES_USER
            - name: DB_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: POSTGRES_PASSWORD
            - name: DB_NAME
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: POSTGRES_DB
            # RustFS 凭证
            - name: LOGO_STORAGE_ACCESS_KEY
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: RUSTFS_ACCESS_KEY
            - name: LOGO_STORAGE_SECRET_KEY
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: RUSTFS_SECRET_KEY
          readinessProbe:
            httpGet:
              path: /ready
              port: 10000
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
          livenessProbe:
            httpGet:
              path: /live
              port: 10000
            initialDelaySeconds: 30
            periodSeconds: 30
            timeoutSeconds: 5
            failureThreshold: 3

---
apiVersion: v1
kind: Service
metadata:
  name: identity-srv
spec:
  selector:
    app: identity-srv
  ports:
    - name: rpc
      port: 8891
      targetPort: 8891
    - name: health
      port: 10000
      targetPort: 10000

---
# =============================================================================
# gateway：Deployment + Service（Hertz HTTP 网关）
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  labels:
    app: gateway
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      restartPolicy: Always
      containers:
        - name: gateway
          image: localhost/gateway:latest
          imagePullPolicy: Never
          ports:
            - name: http
              containerPort: 8080
              hostPort: 8080
          envFrom:
            - configMapRef:
                name: cloudwego-app-env
          env:
            # Redis 密码
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: REDIS_PASSWORD
            # JWT 签名密钥
            - name: JWT_SIGNING_KEY
              valueFrom:
                secretKeyRef:
                  name: cloudwego-secrets
                  key: JWT_SIGNING_KEY
          readinessProbe:
            httpGet:
              path: /ping
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
          livenessProbe:
            httpGet:
              path: /ping
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 30
            timeoutSeconds: 5
            failureThreshold: 3

---
apiVersion: v1
kind: Service
metadata:
  name: gateway
spec:
  selector:
    app: gateway
  ports:
    - name: http
      port: 8080
      targetPort: 8080
